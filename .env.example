APP_NAME=Unbeatentrack
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Full public URL (no trailing slash). Local: http://localhost or http://unbeatentrack.test ; staging: https://staging.unbeatentrack.com
APP_URL=http://localhost

# After cloning: run `php artisan storage:link` so uploaded files under storage/app/public are served from /storage/…

# MapTiler (admin map tiles + “Lookup coordinates” geocoding — proxied / server-side only; never put the key in frontend code)
# MAPTILER_API_KEY=
# MAPTILER_MAP_STYLE=streets-v2
# Outbound Referer for MapTiler when the browser sends none (e.g. curl). Tile proxy prefers the
# incoming request Referer/Origin so local vhosts work even if APP_URL is still http://localhost.
# MAPTILER_HTTP_REFERER="${APP_URL}"

# Optional: AI draft for town "About" in admin (server-side only; never expose keys in the browser)
# TOWN_ABOUT_AI_PROVIDER=auto
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5
# Optional: replace the whole hidden "system" prompt for town drafts (multi-line OK in double-quoted .env)
# TOWN_ABOUT_DRAFT_SYSTEM="Your rules here..."
# Same for POI "About" drafts (optional; defaults in config/town_ai.php)
# POI_ABOUT_DRAFT_SYSTEM="Your POI rules here..."
# Optional: override the hidden system prompt for POI narration script drafts (plain text for ElevenLabs)
# POI_NARRATION_DRAFT_SYSTEM="Your narration rules here..."

# POI voice narration (ElevenLabs — server-side only; never expose the API key)
# ELEVENLABS_API_KEY=
# ELEVENLABS_DEFAULT_VOICE_ID=jSuBIjxMKhqIfb0wCK1F
# Second narration voice (shown as "Sarah" in admin; env key unchanged for existing installs)
# ELEVENLABS_ZOE_VOICE_ID=IwFADcBfc7Yo8KGhxTR5
# ELEVENLABS_DEFAULT_MODEL_ID=eleven_multilingual_v2
# Alternative: eleven_turbo_v2_5 (lower latency; if playback is odd in the browser, keep multilingual).
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io
# POI_NARRATION_PROVIDER=elevenlabs
# POI_NARRATION_ENABLED=true

# Starter POI spreadsheets (defaults match repo layout under htdocs/unbeaten/Data/)
# php artisan pois:import-starter
# php artisan pois:import-starter --dry-run
# php artisan pois:import-starter --vic="C:\path\VIC_POIs_Starter_v1.xlsx" --nsw="C:\path\NSW_POIs_Starter_v1.xlsx"
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Optional: create admin accounts when you run `php artisan db:seed` (see AdminBootstrapSeeder).
# AUTH_BOOTSTRAP_SUPER_EMAIL=
# AUTH_BOOTSTRAP_SUPER_NAME="Your name"
# AUTH_BOOTSTRAP_SUPER_PASSWORD=
# AUTH_BOOTSTRAP_ADMIN_EMAIL=
# AUTH_BOOTSTRAP_ADMIN_NAME="Kath Robertson"
# AUTH_BOOTSTRAP_ADMIN_PASSWORD=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
